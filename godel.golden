    PROV_HF_EXISTS_ELIM : |- (!v. (!P. (!Q. (((is_form P) /\ ((is_form Q) /\ (~((free_in Q) v) /\ (Prov_HF ((Imp_f P) Q))))) ==> (Prov_HF ((Imp_f (Not_f ((Forall_f v) (Not_f P)))) Q))))))
    PROV_HF_SUBST_EQ : |- (!x. (!phi. (!t1. (!t2. (((is_form phi) /\ ((is_term t1) /\ (is_term t2))) ==> (Prov_HF ((Imp_f ((Eq_f t1) t2)) ((Imp_f (((substitute phi) t1) x)) (((substitute phi) t2) x)))))))))
    IS_TERM_VAR_X : |- (is_term var_x)
    IS_TERM_VAR_Y : |- (is_term var_y)

    PROV_HF_IFF_INTRO : |- (!A. (!B. (((is_form A) /\ ((is_form B) /\ ((Prov_HF ((Imp_f A) B)) /\ (Prov_HF ((Imp_f B) A))))) ==> (Prov_HF (Not_f ((Imp_f ((Imp_f A) B)) (Not_f ((Imp_f B) A))))))))

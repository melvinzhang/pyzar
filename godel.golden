    IS_HF_AXIOM_DEF : |- (is_hf_axiom = (\n. ((n = HF1_axiom) \/ ((n = HF2_axiom) \/ ((n = HF3_axiom) \/ ((n = HF4_axiom) \/ (n = HF5_axiom)))))))
    IS_HF_AXIOM_AT  : |- (!n. ((is_hf_axiom n) = ((n = HF1_axiom) \/ ((n = HF2_axiom) \/ ((n = HF3_axiom) \/ ((n = HF4_axiom) \/ (n = HF5_axiom)))))))
    IS_MP_AT       : |- (!f1. (!f2. (!g. ((((is_mp f1) f2) g) = (f2 = ((Imp_f f1) g))))))
    IS_GEN_AT      : |- (!f. (!g. (((is_gen f) g) = (?x. (g = ((Forall_f x) f))))))
    IS_K_AT        : |- (!n. ((is_K n) = (?A. (?B. ((is_form A) /\ ((is_form B) /\ (n = ((Imp_f A) ((Imp_f B) A)))))))))
    IS_S_AT        : |- (!n. ((is_S n) = (?A. (?B. (?C. ((is_form A) /\ ((is_form B) /\ ((is_form C) /\ (n = ((Imp_f ((Imp_f A) ((Imp_f B) C))) ((Imp_f ((Imp_f A) B)) ((Imp_f A) C))))))))))))
    IS_N_AT        : |- (!n. ((is_N n) = (?A. (?B. ((is_form A) /\ ((is_form B) /\ (n = ((Imp_f ((Imp_f (Not_f B)) (Not_f A))) ((Imp_f A) B)))))))))
    IS_UI_AT       : |- (!n. ((is_UI n) = (?x. (?F. (?t. ((is_form F) /\ ((is_term t) /\ (n = ((Imp_f ((Forall_f x) F)) (((substitute F) t) x))))))))))
    IS_VAC_AT      : |- (!n. ((is_Vac n) = (?x. (?F. ((is_form F) /\ (~((free_in F) x) /\ (n = ((Imp_f F) ((Forall_f x) F)))))))))
    IS_REFL_AT     : |- (!n. ((is_Refl n) = (?t. ((is_term t) /\ (n = ((Eq_f t) t))))))
    IS_SUBST_AT    : |- (!n. ((is_Subst n) = (?x. (?F. (?t1. (?t2. ((is_form F) /\ ((is_term t1) /\ ((is_term t2) /\ (n = ((Imp_f ((Eq_f t1) t2)) ((Imp_f (((substitute F) t1) x)) (((substitute F) t2) x)))))))))))))
    IS_HF_IND_AXIOM_AT : |- (!n. ((is_hf_ind_axiom n) = (?F. ((is_form F) /\ (~((free_in F) 0) /\ (~((free_in F) (SUC0 0)) /\ (n = ((Imp_f ((Forall_f (SUC0 0)) ((Imp_f ((Forall_f 0) ((Imp_f ((In_a (Var_t 0)) (Var_t (SUC0 0)))) (((substitute F) (Var_t 0)) (SUC0 (SUC0 0)))))) (((substitute F) (Var_t (SUC0 0))) (SUC0 (SUC0 0)))))) ((Forall_f (SUC0 0)) (((substitute F) (Var_t (SUC0 0))) (SUC0 (SUC0 0))))))))))))
    IS_LOGICAL_AXIOM_AT : |- (!n. ((is_logical_axiom n) = ((is_K n) \/ ((is_S n) \/ ((is_N n) \/ ((is_UI n) \/ ((is_Vac n) \/ ((is_Refl n) \/ ((is_Subst n) \/ (is_FaImp n))))))))))
    IS_AXIOM_AT         : |- (!n. ((is_axiom n) = ((is_hf_axiom n) \/ ((is_hf_ind_axiom n) \/ (is_logical_axiom n)))))
    NUMERAL_BASE : |- ((numeral 0) = Empty_t)
    NUMERAL_STEP : |- (!n. ((numeral (SUC0 n)) = ((Insert_t (numeral n)) (numeral n))))

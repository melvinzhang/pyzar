    FREE_IN_DEF    : |- (free_in = (@hh. (!n. ((hh n) = ((_free_in_F hh) n)))))
    FREE_IN_REC    : |- (!n. ((free_in n) = (\v. ((?x. ((n = (Var_t x)) /\ (v = x))) \/ ((?a. (?b. ((n = ((Eq_f a) b)) /\ (((free_in a) v) \/ ((free_in b) v))))) \/ ((?x. ((n = (Not_f x)) /\ ((free_in x) v))) \/ ((?a. (?b. ((n = ((Imp_f a) b)) /\ (((free_in a) v) \/ ((free_in b) v))))) \/ ((?a. (?b. ((n = ((Forall_f a) b)) /\ (~(v = a) /\ ((free_in b) v))))) \/ ((?a. (?b. ((n = ((Insert_t a) b)) /\ (((free_in a) v) \/ ((free_in b) v))))) \/ (?a. (?b. ((n = ((In_a a) b)) /\ (((free_in a) v) \/ ((free_in b) v))))))))))))))
    FREE_IN_AT_VAR    : |- (!w. (!v. (((free_in (Var_t w)) v) = (v = w))))
    FREE_IN_AT_EQ     : |- (!t1. (!t2. (!v. (((free_in ((Eq_f t1) t2)) v) = (((free_in t1) v) \/ ((free_in t2) v))))))
    FREE_IN_AT_NOT    : |- (!phi. (!v. (((free_in (Not_f phi)) v) = ((free_in phi) v))))
    FREE_IN_AT_IMP    : |- (!phi1. (!phi2. (!v. (((free_in ((Imp_f phi1) phi2)) v) = (((free_in phi1) v) \/ ((free_in phi2) v))))))
    FREE_IN_AT_FORALL : |- (!w. (!phi. (!v. (((free_in ((Forall_f w) phi)) v) = (~(v = w) /\ ((free_in phi) v))))))
    FREE_IN_AT_INSERT : |- (!t1. (!t2. (!v. (((free_in ((Insert_t t1) t2)) v) = (((free_in t1) v) \/ ((free_in t2) v))))))
    FREE_IN_AT_IN     : |- (!t1. (!t2. (!v. (((free_in ((In_a t1) t2)) v) = (((free_in t1) v) \/ ((free_in t2) v))))))
    SUBSTITUTE_MONO         : |- (!f. (!g. (!n. ((!k. (((nat0_lt k) n) ==> ((f k) = (g k)))) ==> (((_substitute_F f) n) = ((_substitute_F g) n))))))
    SUBSTITUTE_DEF          : |- (substitute = (@hh. (!n. ((hh n) = ((_substitute_F hh) n)))))
    SUBSTITUTE_REC          : |- (!n. ((substitute n) = (\new_t. (\v. (@r. (((n = Empty_t) /\ (r = Empty_t)) \/ ((?x. ((n = (Var_t x)) /\ (((v = x) /\ (r = new_t)) \/ (~(v = x) /\ (r = (Var_t x)))))) \/ ((?a. (?b. ((n = ((Eq_f a) b)) /\ (r = ((Eq_f (((substitute a) new_t) v)) (((substitute b) new_t) v)))))) \/ ((?x. ((n = (Not_f x)) /\ (r = (Not_f (((substitute x) new_t) v))))) \/ ((?a. (?b. ((n = ((Imp_f a) b)) /\ (r = ((Imp_f (((substitute a) new_t) v)) (((substitute b) new_t) v)))))) \/ ((?a. (?b. ((n = ((Forall_f a) b)) /\ (((v = a) /\ (r = ((Forall_f a) b))) \/ (~(v = a) /\ (r = ((Forall_f a) (((substitute b) new_t) v)))))))) \/ ((?a. (?b. ((n = ((Insert_t a) b)) /\ (r = ((Insert_t (((substitute a) new_t) v)) (((substitute b) new_t) v)))))) \/ (?a. (?b. ((n = ((In_a a) b)) /\ (r = ((In_a (((substitute a) new_t) v)) (((substitute b) new_t) v))))))))))))))))))
    SUBSTITUTE_AT_EMPTY     : |- (!new_t. (!v. ((((substitute Empty_t) new_t) v) = Empty_t)))
    SUBSTITUTE_AT_VAR_HIT   : |- (!x. (!new_t. (!v. ((v = x) ==> ((((substitute (Var_t x)) new_t) v) = new_t)))))
    SUBSTITUTE_AT_VAR_MISS  : |- (!x. (!new_t. (!v. (~(v = x) ==> ((((substitute (Var_t x)) new_t) v) = (Var_t x))))))
    SUBSTITUTE_AT_EQ        : |- (!t1. (!t2. (!new_t. (!v. ((((substitute ((Eq_f t1) t2)) new_t) v) = ((Eq_f (((substitute t1) new_t) v)) (((substitute t2) new_t) v)))))))
    SUBSTITUTE_AT_NOT       : |- (!phi. (!new_t. (!v. ((((substitute (Not_f phi)) new_t) v) = (Not_f (((substitute phi) new_t) v))))))
    SUBSTITUTE_AT_IMP       : |- (!phi1. (!phi2. (!new_t. (!v. ((((substitute ((Imp_f phi1) phi2)) new_t) v) = ((Imp_f (((substitute phi1) new_t) v)) (((substitute phi2) new_t) v)))))))
    SUBSTITUTE_AT_FORALL_HIT : |- (!a. (!b. (!new_t. (!v. ((v = a) ==> ((((substitute ((Forall_f a) b)) new_t) v) = ((Forall_f a) b)))))))
    SUBSTITUTE_AT_FORALL_MISS: |- (!a. (!b. (!new_t. (!v. (~(v = a) ==> ((((substitute ((Forall_f a) b)) new_t) v) = ((Forall_f a) (((substitute b) new_t) v))))))))
    SUBSTITUTE_AT_INSERT     : |- (!t1. (!t2. (!new_t. (!v. ((((substitute ((Insert_t t1) t2)) new_t) v) = ((Insert_t (((substitute t1) new_t) v)) (((substitute t2) new_t) v)))))))
    SUBSTITUTE_AT_IN         : |- (!t1. (!t2. (!new_t. (!v. ((((substitute ((In_a t1) t2)) new_t) v) = ((In_a (((substitute t1) new_t) v)) (((substitute t2) new_t) v)))))))
    SUBSTITUTE_PRESERVES_IS_TERM : |- (!n. (!t. (!v. (((is_term n) /\ (is_term t)) ==> (is_term (((substitute n) t) v))))))

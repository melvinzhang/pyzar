    VAR_A2_DEF              : |- (var_a2 = (Var_t (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 0)))))))))))))
    VAR_B1_DEF              : |- (var_b1 = (Var_t (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 0))))))))))))))
    VAR_B2_DEF              : |- (var_b2 = (Var_t (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 0)))))))))))))))
    VAR_F1_DEF              : |- (var_f1 = (Var_t (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 0))))))))))))))))
    VAR_F2_DEF              : |- (var_f2 = (Var_t (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 (SUC0 0)))))))))))))))))
    IS_SUBSTITUTE_STEP_DEF : |- (is_substitute_step = (\T. (\t. (\v. (\a. (\b. (((a = Empty_t) /\ (b = Empty_t)) \/ (((a = (Var_t v)) /\ (b = t)) \/ ((?w. ((a = (Var_t w)) /\ (~(w = v) /\ (b = (Var_t w))))) \/ ((?a1. (?a2. (?b1. (?b2. ((a = ((Eq_f a1) a2)) /\ ((b = ((Eq_f b1) b2)) /\ (((In ((Pair_ord a1) b1)) T) /\ ((In ((Pair_ord a2) b2)) T)))))))) \/ ((?s1. (?s2. ((a = (Not_f s1)) /\ ((b = (Not_f s2)) /\ ((In ((Pair_ord s1) s2)) T))))) \/ ((?a1. (?a2. (?b1. (?b2. ((a = ((Imp_f a1) a2)) /\ ((b = ((Imp_f b1) b2)) /\ (((In ((Pair_ord a1) b1)) T) /\ ((In ((Pair_ord a2) b2)) T)))))))) \/ ((?w. (?f1. ((a = ((Forall_f w) f1)) /\ ((w = v) /\ (b = ((Forall_f w) f1)))))) \/ ((?w. (?f1. (?f2. ((a = ((Forall_f w) f1)) /\ (~(w = v) /\ ((b = ((Forall_f w) f2)) /\ ((In ((Pair_ord f1) f2)) T))))))) \/ ((?a1. (?a2. (?b1. (?b2. ((a = ((Insert_t a1) a2)) /\ ((b = ((Insert_t b1) b2)) /\ (((In ((Pair_ord a1) b1)) T) /\ ((In ((Pair_ord a2) b2)) T)))))))) \/ (?a1. (?a2. (?b1. (?b2. ((a = ((In_a a1) a2)) /\ ((b = ((In_a b1) b2)) /\ (((In ((Pair_ord a1) b1)) T) /\ ((In ((Pair_ord a2) b2)) T)))))))))))))))))))))))
    IS_SUBSTITUTE_TRACE_DEF: |- (is_substitute_trace = (\T. (\F. (\t. (\v. (\r. (((In ((Pair_ord F) r)) T) /\ (!a. (!b. (((In ((Pair_ord a) b)) T) ==> (((((is_substitute_step T) t) v) a) b)))))))))))
    IS_SUBSTITUTE_TRACE_AT : |- (!T. (!F. (!t. (!v. (!r. ((((((is_substitute_trace T) F) t) v) r) = (((In ((Pair_ord F) r)) T) /\ (!a. (!b. (((In ((Pair_ord a) b)) T) ==> (((((is_substitute_step T) t) v) a) b)))))))))))
    TRACE_STEP_MONO                       : |- (!T1. (!T2. ((!x. (((In x) T1) ==> ((In x) T2))) ==> (!t. (!v. (!a. (!b. ((((((is_substitute_step T1) t) v) a) b) ==> (((((is_substitute_step T2) t) v) a) b)))))))))
    TRACE_EXISTS                          : |- (!n. (!t. (!v. (((is_term n) \/ (is_form n)) ==> (?T. (((((is_substitute_trace T) n) t) v) (((substitute n) t) v)))))))
    QUOTE_HF_AT_EMPTY                    : |- ((quote_hf Empty) = Empty_t)
    QUOTE_HF_AT_INSERT_LOW               : |- (!i. (!s. (((s = 0) \/ ((nat0_lt i) (low_bit s))) ==> ((quote_hf ((Insert i) s)) = ((Insert_t (quote_hf i)) (quote_hf s))))))
    QUOTE_HF_AT_SINGLETON                : |- (!x. ((quote_hf (Singleton x)) = ((Insert_t (quote_hf x)) Empty_t)))
    QUOTE_HF_AT_PAIR                      : |- (!x. (!y. (((nat0_lt x) y) ==> ((quote_hf ((Pair x) y)) = ((Insert_t (quote_hf x)) ((Insert_t (quote_hf y)) Empty_t))))))
    QUOTE_HF_AT_PAIR_ORD                  : |- (!x. (!y. (((nat0_lt x) y) ==> ((quote_hf ((Pair_ord x) y)) = ((Insert_t ((Insert_t (quote_hf x)) Empty_t)) ((Insert_t ((Insert_t (quote_hf x)) ((Insert_t (quote_hf y)) Empty_t))) Empty_t))))))
    HF_INDUCTION                          : |- (!P. (((P Empty) /\ (!i. (!s. (((s = 0) \/ ((nat0_lt i) (low_bit s))) ==> ((P s) ==> (P ((Insert i) s))))))) ==> (!n. (P n))))
    IS_TERM_QUOTE_HF                      : |- (!n. (is_term (quote_hf n)))
    SUBSTITUTE_QUOTE_HF                   : |- (!n. (!t. (!v. ((((substitute (quote_hf n)) t) v) = (quote_hf n)))))
    IS_PAIR_ORD_INTERNAL_DEF              : |- (is_Pair_ord_internal = ((Eq_f var_z) ((Insert_t ((Insert_t var_x) Empty_t)) ((Insert_t ((Insert_t var_x) ((Insert_t var_y) Empty_t))) Empty_t))))
    PROV_HF_REFL                          : |- (!t. ((is_term t) ==> (Prov_HF ((Eq_f t) t))))
    IS_PAIR_ORD_REPRESENTS                : |- (!x. (!y. (((nat0_lt x) y) ==> (Prov_HF (((substitute (((substitute (((substitute is_Pair_ord_internal) (quote_hf x)) idx_x)) (quote_hf y)) idx_y)) (quote_hf ((Pair_ord x) y))) idx_z)))))
    SUBSTITUTE_2_DEF        : |- (substitute_2 = (\F. (\a. (\b. (\vx. (\vy. (((substitute (((substitute F) a) vx)) b) vy)))))))
    PROV_HF_K : |- (!A. (!B. (((is_form A) /\ (is_form B)) ==> (Prov_HF ((Imp_f A) ((Imp_f B) A))))))
    PROV_HF_S : |- (!A. (!B. (!C. (((is_form A) /\ ((is_form B) /\ (is_form C))) ==> (Prov_HF ((Imp_f ((Imp_f A) ((Imp_f B) C))) ((Imp_f ((Imp_f A) B)) ((Imp_f A) C))))))))
    PROV_HF_N : |- (!A. (!B. (((is_form A) /\ (is_form B)) ==> (Prov_HF ((Imp_f ((Imp_f (Not_f B)) (Not_f A))) ((Imp_f A) B))))))
    PROV_HF_UI_IMP : |- (!x. (!phi. (!t. (((is_form phi) /\ (is_term t)) ==> (Prov_HF ((Imp_f ((Forall_f x) phi)) (((substitute phi) t) x)))))))

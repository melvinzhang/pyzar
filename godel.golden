    QUOTE_HF_MEM_HEAD_NEQ_RAW_DECREASE: |- (!x. (!y. ((~(y = 0) /\ ~(x = (low_bit y))) ==> (((nat0_lt ((quote_hf_mem_measure x) (low_bit y))) ((quote_hf_mem_measure x) y)) /\ ((nat0_lt ((quote_hf_mem_measure (low_bit y)) x)) ((quote_hf_mem_measure x) y))))))

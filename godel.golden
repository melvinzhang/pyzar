    IS_TERM_INSERT   : |- (!t1. (!t2. (((is_term t1) /\ (is_term t2)) ==> (is_term ((Insert_t t1) t2)))))
    IS_TERM_NUMERAL  : |- (!n. (is_term (numeral n)))
    VALID_STEP_HF_SET_DEF       : |- (valid_step_hf_set = (\P. (\k. (\h. ((is_axiom h) \/ ((?i. (?f. (?j. (?g. (((In ((Pair_ord i) f)) P) /\ (((In ((Pair_ord j) g)) P) /\ (((nat0_lt i) k) /\ (((nat0_lt j) k) /\ (((is_mp f) g) h))))))))) \/ (?i. (?f. (((In ((Pair_ord i) f)) P) /\ (((nat0_lt i) k) /\ ((is_gen f) h)))))))))))
    VALID_STEP_HF_SET_AT        : |- (!P. (!k. (!h. ((((valid_step_hf_set P) k) h) = ((is_axiom h) \/ ((?i. (?f. (?j. (?g. (((In ((Pair_ord i) f)) P) /\ (((In ((Pair_ord j) g)) P) /\ (((nat0_lt i) k) /\ (((nat0_lt j) k) /\ (((is_mp f) g) h))))))))) \/ (?i. (?f. (((In ((Pair_ord i) f)) P) /\ (((nat0_lt i) k) /\ ((is_gen f) h)))))))))))
    PROOF_HF_SET_DEF            : |- (Proof_HF_set = (\P. (\n. (?k. (((In ((Pair_ord k) n)) P) /\ (!j. (!h. (((In ((Pair_ord j) h)) P) ==> (((valid_step_hf_set P) j) h)))))))))
    PROOF_HF_SET_AT             : |- (!P. (!n. (((Proof_HF_set P) n) = (?k. (((In ((Pair_ord k) n)) P) /\ (!j. (!h. (((In ((Pair_ord j) h)) P) ==> (((valid_step_hf_set P) j) h)))))))))
    VALID_STEP_HF_SET_PRESERVES : |- (!P. (!Q. (!k. (!h. ((!x. (((In x) P) ==> ((In x) Q))) ==> ((((valid_step_hf_set P) k) h) ==> (((valid_step_hf_set Q) k) h)))))))
    AXIOM_HAS_PROOF_HF_SET      : |- (!m. ((is_axiom m) ==> (?P. ((Proof_HF_set P) m))))
    MP_HAS_PROOF_HF_SET         : |- (!f. (!g. (((?P. ((Proof_HF_set P) f)) /\ (?Q. ((Proof_HF_set Q) ((Imp_f f) g)))) ==> (?R. ((Proof_HF_set R) g)))))
    GEN_HAS_PROOF_HF_SET        : |- (!f. (!x. ((?P. ((Proof_HF_set P) f)) ==> (?R. ((Proof_HF_set R) ((Forall_f x) f))))))
    PROV_HF_DEF         : |- (Prov_HF = (\n. (?P. ((Proof_HF_set P) n))))
    PROV_HF_AT          : |- (!n. ((Prov_HF n) = (?P. ((Proof_HF_set P) n))))
    PROV_HF_AXIOM       : |- (!n. ((is_axiom n) ==> (Prov_HF n)))
    PROV_HF_MP          : |- (!f. (!g. (((Prov_HF f) /\ (Prov_HF ((Imp_f f) g))) ==> (Prov_HF g))))
    PROV_HF_GEN         : |- (!f. (!x. ((Prov_HF f) ==> (Prov_HF ((Forall_f x) f)))))
    PROV_HF_IFF_PROOF_HF_SET : |- (!n. ((Prov_HF n) = (?P. ((Proof_HF_set P) n))))
    REPRESENTS_PRED_DEF : |- (represents_pred = (\F. (\P. ((!n. ((P n) ==> (Prov_HF (((substitute F) (numeral n)) 0)))) /\ (!n. (~(P n) ==> (Prov_HF (Not_f (((substitute F) (numeral n)) 0)))))))))
    REPRESENTS_PRED_AT  : |- (!F. (!P. (((represents_pred F) P) = ((!n. ((P n) ==> (Prov_HF (((substitute F) (numeral n)) 0)))) /\ (!n. (~(P n) ==> (Prov_HF (Not_f (((substitute F) (numeral n)) 0)))))))))
    VAR_Z_DEF              : |- (var_z = (Var_t (SUC0 (SUC0 0))))

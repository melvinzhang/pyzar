    HF3_INST      : |- (!a. (!b. (!c. ((((is_term a) /\ ((is_term b) /\ (is_term c))) /\ (((((substitute a) b) (SUC0 0)) = a) /\ (((((substitute a) c) (SUC0 (SUC0 0))) = a) /\ ((((substitute b) c) (SUC0 (SUC0 0))) = b)))) ==> (Prov_HF ((Imp_f (Not_f ((Eq_f a) b))) (Not_f ((Imp_f ((Imp_f ((In_a b) ((Insert_t a) c))) ((In_a b) c))) (Not_f ((Imp_f ((In_a b) c)) ((In_a b) ((Insert_t a) c))))))))))))
    QUOTE_HF_INJ  : |- (!n. (!t. (((quote_hf n) = (quote_hf t)) ==> (n = t))))
    HF4_INST                       : |- (!a. (!b. (((is_term a) /\ ((is_term b) /\ ((((substitute a) b) (SUC0 0)) = a))) ==> (Prov_HF ((Imp_f ((Forall_f (SUC0 (SUC0 0))) (Not_f ((Imp_f ((Imp_f ((In_a (Var_t (SUC0 (SUC0 0)))) a)) ((In_a (Var_t (SUC0 (SUC0 0)))) b))) (Not_f ((Imp_f ((In_a (Var_t (SUC0 (SUC0 0)))) b)) ((In_a (Var_t (SUC0 (SUC0 0)))) a))))))) ((Eq_f a) b))))))
    PROV_HF_NEQ_FROM_MEM_DIFF     : |- (!w. (!s. (!t. (((is_term s) /\ ((is_term t) /\ ((Prov_HF ((In_a (quote_hf w)) s)) /\ (Prov_HF (Not_f ((In_a (quote_hf w)) t)))))) ==> (Prov_HF (Not_f ((Eq_f s) t)))))))

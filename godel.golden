    SUBSTITUTE_AT_AND        : |- (!a. (!b. (!t. (!v. ((((substitute ((And_f a) b)) t) v) = ((And_f (((substitute a) t) v)) (((substitute b) t) v)))))))
    SUBSTITUTE_AT_OR         : |- (!a. (!b. (!t. (!v. ((((substitute ((Or_f a) b)) t) v) = ((Or_f (((substitute a) t) v)) (((substitute b) t) v)))))))
    SUBSTITUTE_AT_IFF        : |- (!a. (!b. (!t. (!v. ((((substitute ((Iff_f a) b)) t) v) = ((Iff_f (((substitute a) t) v)) (((substitute b) t) v)))))))
    SUBSTITUTE_AT_EXISTS_MISS: |- (!w. (!body. (!t. (!v. (~(v = w) ==> ((((substitute ((Exists_f w) body)) t) v) = ((Exists_f w) (((substitute body) t) v))))))))
    VAR_X_DEF      : |- (var_x = (Var_t 0))
    VAR_Y_DEF      : |- (var_y = (Var_t (SUC0 0)))

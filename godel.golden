    QUOTE_HF_CERTIFIED_NEQ_FROM_MEM_DIFF  : |- (!w. (!s. (!t. ((((In w) s) /\ ~((In w) t)) ==> (Prov_HF (Not_f ((Eq_f (quote_hf s)) (quote_hf t))))))))

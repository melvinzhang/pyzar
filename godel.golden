    AND_F_DEF                : |- (And_f = (\a. (\b. (Not_f ((Imp_f a) (Not_f b))))))
    AND_F_AT                 : |- (!a. (!b. (((And_f a) b) = (Not_f ((Imp_f a) (Not_f b))))))
    OR_F_DEF                 : |- (Or_f = (\a. (\b. ((Imp_f (Not_f a)) b))))
    OR_F_AT                  : |- (!a. (!b. (((Or_f a) b) = ((Imp_f (Not_f a)) b))))
    IFF_F_DEF                : |- (Iff_f = (\a. (\b. ((And_f ((Imp_f a) b)) ((Imp_f b) a)))))
    IFF_F_AT                 : |- (!a. (!b. (((Iff_f a) b) = ((And_f ((Imp_f a) b)) ((Imp_f b) a)))))
    EXISTS_F_DEF             : |- (Exists_f = (\v. (\f. (Not_f ((Forall_f v) (Not_f f))))))

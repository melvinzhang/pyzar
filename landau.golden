  SATZ_105C:      |- (!X. (!Y. (!Z. ((X rlt Y) ==> ((X rmul Z) rlt (Y rmul Z))))))
  SATZ_106A:      |- (!X. (!Y. (!Z. (((X rmul Z) rgt (Y rmul Z)) ==> (X rgt Y)))))
  SATZ_106B:      |- (!X. (!Y. (!Z. (((X rmul Z) = (Y rmul Z)) ==> (X = Y)))))
  SATZ_106C:      |- (!X. (!Y. (!Z. (((X rmul Z) rlt (Y rmul Z)) ==> (X rlt Y)))))
  SATZ_107:       |- (!X. (!Y. (!Z. (!U. ((X rgt Y) ==> ((Z rgt U) ==> ((X rmul Z) rgt (Y rmul U))))))))
  SATZ_108A:      |- (!X. (!Y. (!Z. (!U. ((X rge Y) ==> ((Z rgt U) ==> ((X rmul Z) rgt (Y rmul U))))))))
  SATZ_108B:      |- (!X. (!Y. (!Z. (!U. ((X rgt Y) ==> ((Z rge U) ==> ((X rmul Z) rgt (Y rmul U))))))))
  SATZ_109:       |- (!X. (!Y. (!Z. (!U. ((X rge Y) ==> ((Z rge U) ==> ((X rmul Z) rge (Y rmul U))))))))
  SATZ_110_EXIST: |- (!X. (!Y. (?U. ((Y rmul U) = X))))
  SATZ_110_UNIQ:  |- (!X. (!Y. (!V. (!W. (((Y rmul V) = X) ==> (((Y rmul W) = X) ==> (V = W)))))))
  RDIV_PROP:      |- (!X. (!Y. ((Y rmul (X rdiv Y)) = X)))
  SATZ_111A_FWD:  |- (!x. (!y. ((((Q x) 1) rgt ((Q y) 1)) ==> (x > y))))
  SATZ_111A_REV:  |- (!x. (!y. ((x > y) ==> (((Q x) 1) rgt ((Q y) 1)))))
  SATZ_111B_FWD:  |- (!x. (!y. ((((Q x) 1) = ((Q y) 1)) ==> (x = y))))
  SATZ_111B_REV:  |- (!x. (!y. ((x = y) ==> (((Q x) 1) = ((Q y) 1)))))
  SATZ_111C_FWD:  |- (!x. (!y. ((((Q x) 1) rlt ((Q y) 1)) ==> (x < y))))
  SATZ_111C_REV:  |- (!x. (!y. ((x < y) ==> (((Q x) 1) rlt ((Q y) 1)))))

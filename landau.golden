  SATZ_98:        |- (!X. (!Y. (!Z. (!U. ((X rgt Y) ==> ((Z rgt U) ==> ((X radd Z) rgt (Y radd U))))))))
  SATZ_99A:       |- (!X. (!Y. (!Z. (!U. ((X rge Y) ==> ((Z rgt U) ==> ((X radd Z) rgt (Y radd U))))))))
  SATZ_99B:       |- (!X. (!Y. (!Z. (!U. ((X rgt Y) ==> ((Z rge U) ==> ((X radd Z) rgt (Y radd U))))))))
  SATZ_100:       |- (!X. (!Y. (!Z. (!U. ((X rge Y) ==> ((Z rge U) ==> ((X radd Z) rge (Y radd U))))))))
  SATZ_101_EXIST: |- (!X. (!Y. ((X rgt Y) ==> (?U. ((Y radd U) = X)))))
  SATZ_101_UNIQ:  |- (!X. (!Y. (!V. (!W. (((Y radd V) = X) ==> (((Y radd W) = X) ==> (V = W)))))))
  RSUB_PROP:      |- (!X. (!Y. ((X rgt Y) ==> ((Y radd (X rsub Y)) = X))))
  RMUL_QQ:        |- (!a. (!b. (!c. (!d. ((((Q a) b) rmul ((Q c) d)) = ((Q (a * c)) (b * d)))))))
  SATZ_102:       |- (!X. (!Y. ((X rmul Y) = (Y rmul X))))

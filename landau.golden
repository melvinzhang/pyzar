  SATZ_104:       |- (!X. (!Y. (!Z. ((X rmul (Y radd Z)) = ((X rmul Y) radd (X rmul Z))))))
  SATZ_105A:      |- (!X. (!Y. (!Z. ((X rgt Y) ==> ((X rmul Z) rgt (Y rmul Z))))))
